APP_ENV=local
APP_NAME=moira
APP_DEBUG=true
DATABASE_URL=postgresql+asyncpg://moira:moira@localhost:5432/moira
JWT_SECRET_KEY=change-me-in-local-dev-secret-at-least-32-bytes
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
PASSWORD_HASH_SCHEME=bcrypt
DEFAULT_TIMEZONE=America/Fortaleza
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_EXPORTERS=stdout
# Required only when LOG_EXPORTERS=stdout,otlp
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://localhost:4318/v1/logs
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_TIMEOUT=5
OTEL_SERVICE_NAME=moira
CACHE_ENABLED=true
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_PUBLIC_PROVIDER_SECONDS=1800
CACHE_TTL_PUBLIC_OFFERINGS_SECONDS=600
CACHE_TTL_AVAILABLE_SLOTS_SECONDS=30
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
